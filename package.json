{
  "name": "ngx-inline-filter",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "publish": "ng build ngx-inline-filter && cd dist/ngx-inline-filter && npm publish && cd ../..",
    "sb": "ng run ngx-inline-filter:storybook",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "format": "prettier --write \"projects/**/*.{ts,scss,html}\""
  },
  "private": true,
  "dependencies": {
    "@angular/common": "^21.1.2",
    "@angular/compiler": "^21.1.2",
    "@angular/core": "^21.1.2",
    "@angular/forms": "^21.1.2",
    "rxjs": "~7.8.2",
    "tslib": "^2.8.1",
    "zone.js": "~0.16.0"
  },
  "devDependencies": {
    "@analogjs/storybook-angular": "^2.2.3",
    "@angular-devkit/build-angular": "^21.1.2",
    "@angular/build": "^21.1.2",
    "@angular/cli": "^21.1.2",
    "@angular/compiler-cli": "^21.1.2",
    "@angular/platform-browser": "^21.1.2",
    "@angular/platform-browser-dynamic": "^21.1.2",
    "@storybook/addon-docs": "^10.2.6",
    "@storybook/addon-onboarding": "^10.2.6",
    "jsdom": "^28.0.0",
    "ng-packagr": "^21.1.0",
    "prettier": "3.8.1",
    "squidex-prettier-plugin-organize-attributes": "^1.0.1",
    "storybook": "^10.2.6",
    "typescript": "~5.9.3",
    "vitest": "^4.0.18"
  },
  "workspaces": [
    "projects/*"
  ]
